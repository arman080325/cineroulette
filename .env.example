# Copy to .env and fill in. Never commit the real .env — it's in .gitignore.

# Postgres (Neon recommended — free, doesn't expire)
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# TMDB — primary data source (Section 14). Get a free key at
# https://www.themoviedb.org/settings/api
TMDB_API_KEY=

# Optional supplemental sources (Section 14) — leave blank to skip until needed
OMDB_API_KEY=
JUSTWATCH_API_KEY=

# Optional AI natural-language layer (Section 08) — v2 scope, not needed for MVP
AI_PROVIDER_API_KEY=

# How many TMDB discover pages to pull per sync worker run (20 titles/page)
SYNC_PAGES_PER_RUN=10
SYNC_PAGES_PER_LANGUAGE=5
SYNC_PAGES_POPULAR=5
SYNC_LANGUAGES=en,hi,ko,ja,fr,es,de,it,zh,tr,pt,ru
SYNC_CONCURRENCY=8

UPSTASH_REDIS_REST_URL="https://xxx.upstash.io"
UPSTASH_REDIS_REST_TOKEN=

NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

NEXT_PUBLIC_SITE_URL=

OMDB_API_KEY=
OMDB_MAX_LOOKUPS_PER_RUN=300
QUALITY_FLOOR_PERCENTILE=0.1