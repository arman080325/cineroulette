{
  "name": "cineroulette",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "services/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "dotenv -e .env -- npm run dev -w apps/web",
    "sync": "dotenv -e .env -- npm run start -w services/sync-worker",
    "db:generate": "dotenv -e .env -- npm run generate -w packages/db",
    "db:migrate": "dotenv -e .env -- npm run migrate -w packages/db",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present"
  },
  "devDependencies": {
    "typescript": "^5.5.4",
    "@types/node": "^20.14.0",
    "dotenv-cli": "^11.0.0"
  },
  "engines": {
    "node": ">=20"
  }
}
